<view class="container">
  <!-- 未登录状态 -->
  <view class="login-card" wx:if="{{!isLoggedIn}}">
    <view class="login-content">
      <text class="login-icon">👤</text>
      <text class="login-title">欢迎使用智课笔记</text>
      <text class="login-desc">登录后可以保存学习记录</text>
      <button class="login-btn" bindtap="wxLogin">微信登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="profile-content" wx:if="{{isLoggedIn}}">
    <!-- 用户信息 -->
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-id">ID: AI-GROUP-20</text>
      </view>
    </view>

    <!-- 学习统计 -->
    <view class="stats-card">
      <view class="stats-header">
        <text class="stats-title">学习统计</text>
      </view>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-value">{{stats.totalNotes}}</text>
          <text class="stat-label">笔记总数</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.totalCourses}}</text>
          <text class="stat-label">课程数量</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.studyHours}}</text>
          <text class="stat-label">学习时长(h)</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.qaCount}}</text>
          <text class="stat-label">答疑次数</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-card">
      <view class="menu-header">
        <text class="menu-title">我的内容</text>
      </view>
      <view class="menu-list">
        <view class="menu-item" wx:for="{{menuList}}" wx:key="id" bindtap="goToMenu" data-id="{{item.id}}">
          <text class="menu-icon">{{item.icon}}</text>
          <text class="menu-name">{{item.name}}</text>
          <text class="menu-count">{{item.count > 0 ? item.count : ''}}</text>
          <text class="menu-arrow">></text>
        </view>
      </view>
    </view>

    <!-- 设置 -->
    <view class="settings-card">
      <view class="settings-header">
        <text class="settings-title">设置</text>
      </view>
      <view class="settings-list">
        <view class="setting-item" wx:for="{{settings}}" wx:key="id" bindtap="toggleSetting" data-id="{{item.id}}">
          <text class="setting-icon">{{item.icon}}</text>
          <text class="setting-name">{{item.name}}</text>
          <text class="setting-value" wx:if="{{item.enabled !== undefined}}">
            {{item.enabled ? '开启' : '关闭'}}
          </text>
          <text class="setting-value" wx:if="{{item.value}}">{{item.value}}</text>
          <text class="setting-arrow">></text>
        </view>
      </view>
    </view>

    <!-- 其他操作 -->
    <view class="actions-card">
      <view class="action-item" bindtap="goToCloudStorage">
        <text class="action-icon">☁️</text>
        <text class="action-name">云存储管理</text>
      </view>
      <view class="action-item" bindtap="goToConfig">
        <text class="action-icon">⚙️</text>
        <text class="action-name">API配置</text>
      </view>
      <view class="action-item" bindtap="cleanupDuplicates">
        <text class="action-icon">🧹</text>
        <text class="action-name">清理重复数据</text>
      </view>
      <view class="action-item" bindtap="goToHelp">
        <text class="action-icon">❓</text>
        <text class="action-name">帮助中心</text>
      </view>
      <view class="action-item" bindtap="clearCache">
        <text class="action-icon">🗑️</text>
        <text class="action-name">清除缓存</text>
      </view>
      <view class="action-item" bindtap="logout">
        <text class="action-icon">🚪</text>
        <text class="action-name">退出登录</text>
      </view>
      <view class="action-item" bindtap="showAbout">
        <text class="action-icon">ℹ️</text>
        <text class="action-name">关于我们</text>
      </view>
    </view>
  </view>
</view>