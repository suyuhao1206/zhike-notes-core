<view class="search-container">
  <!-- 搜索框 -->
  <view class="search-box">
    <view class="search-input-wrap">
      <image class="search-icon" src="/images/search.png" mode="aspectFit"/>
      <input
        class="search-input"
        placeholder="搜索笔记、课程内容..."
        value="{{query}}"
        bindinput="onInput"
        confirm-type="search"
        bindconfirm="search"
      />
      <image wx:if="{{query}}" class="clear-icon" src="/images/close.png" mode="aspectFit" bindtap="clearSearch"/>
    </view>
    <view class="search-btn" bindtap="search">搜索</view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{hasSearched}}" class="search-result">
    <view wx:if="{{isLoading}}" class="loading">
      <view class="loading-spinner"></view>
      <text>搜索中...</text>
    </view>

    <view wx:elif="{{notes.length === 0}}" class="empty-result">
      <image class="empty-icon" src="/images/empty.png" mode="aspectFit"/>
      <text>未找到相关笔记</text>
    </view>

    <view wx:else class="note-list">
      <view
        wx:for="{{notes}}"
        wx:key="id"
        class="note-item"
        bindtap="viewNote"
        data-id="{{item.id}}"
      >
        <view class="note-title">{{item.title}}</view>
        <view class="note-summary">{{item.summary}}</view>
        <view class="note-meta">
          <text class="note-course">{{item.courseName}}</text>
          <text class="note-time">{{item.createTimeFormatted}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索历史和热门标签 -->
  <view wx:else class="search-suggestions">
    <!-- 搜索历史 -->
    <view wx:if="{{searchHistory.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="clear-btn" bindtap="clearHistory">清空</text>
      </view>
      <view class="tag-list">
        <view
          wx:for="{{searchHistory}}"
          wx:key="*this"
          class="tag"
          bindtap="onHistoryTap"
          data-query="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 热门标签 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">热门标签</text>
      </view>
      <view class="tag-list">
        <view
          wx:for="{{hotTags}}"
          wx:key="*this"
          class="tag hot"
          bindtap="onTagTap"
          data-tag="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>
  </view>
</view>