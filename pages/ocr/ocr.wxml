<view class="container">
  <!-- 图片选择区域 -->
  <view class="upload-section">
    <block wx:if="{{!imagePath}}">
      <view class="upload-box" bindtap="chooseImage">
        <view class="upload-icon">📷</view>
        <text class="upload-text">点击拍照或选择图片</text>
        <text class="upload-hint">支持黑板、PPT、教材等内容识别</text>
      </view>
    </block>
    <block wx:else>
      <view class="image-preview">
        <image src="{{imagePath}}" mode="aspectFit" class="preview-img"></image>
        <view class="image-actions">
          <button class="img-action-btn" bindtap="chooseImage">更换图片</button>
          <button class="img-action-btn" bindtap="retryRecognize" disabled="{{isRecognizing}}">重新识别</button>
        </view>
      </view>
    </block>
  </view>

  <!-- 识别结果 -->
  <block wx:if="{{recognizedText}}">
    <view class="result-section">
      <view class="section-header">
        <text class="section-title">识别结果</text>
        <button class="copy-btn" bindtap="copyText">复制文本</button>
      </view>
      <view class="result-content">
        <text class="result-text" user-select>{{recognizedText}}</text>
      </view>
      <view class="ocr-notice" wx:if="{{ocrNotice}}">
        <text>{{ocrNotice}}</text>
      </view>
    </view>

    <!-- 保存选项 -->
    <view class="save-section">
      <view class="section-header">
        <text class="section-title">保存为笔记</text>
      </view>

      <view class="form-item">
        <text class="form-label">笔记标题</text>
        <input type="text" value="{{noteTitle}}" bindinput="onTitleInput" placeholder="输入笔记标题" />
      </view>

      <view class="form-item">
        <text class="form-label">选择课程</text>
        <picker bindchange="onCourseChange" value="{{courseIndex}}" range="{{courseList}}" range-key="name">
          <view class="picker-value">
            {{(courseList.length > courseIndex && courseList[courseIndex] && courseList[courseIndex].name) ? courseList[courseIndex].name : '请选择课程'}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-actions">
        <button class="save-btn primary" bindtap="saveAsNoteHandler">保存笔记</button>
        <button class="save-btn" bindtap="clearAll">清空</button>
      </view>
    </view>
  </block>

  <!-- 识别中 -->
  <view wx:if="{{isRecognizing}}" class="recognizing-mask">
    <view class="recognizing-box">
      <view class="spinner"></view>
      <text class="recognizing-text">正在识别...</text>
    </view>
  </view>

  <!-- 使用说明 -->
  <view wx:if="{{!imagePath && !isRecognizing}}" class="tips-section">
    <view class="tips-title">💡 使用提示</view>
    <view class="tips-list">
      <text class="tip-item">1. 确保图片清晰，文字可见</text>
      <text class="tip-item">2. 尽量正面拍摄，避免倾斜</text>
      <text class="tip-item">3. 识别后可直接保存为笔记</text>
      <text class="tip-item">4. 需要配置 Coze API 才能使用真实识别</text>
    </view>
  </view>
</view>
