.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 上传区域 */
.upload-section {
  margin-bottom: 20rpx;
}

.upload-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  border: 2rpx dashed #ddd;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.upload-hint {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 图片预览 */
.image-preview {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.preview-img {
  width: 100%;
  max-height: 400rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.image-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.img-action-btn {
  margin: 0;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  color: #333;
  border-radius: 8rpx;
}

/* 结果区域 */
.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.copy-btn {
  margin: 0;
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  background: #1890FF;
  color: #fff;
  border-radius: 6rpx;
}

.result-content {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
}

.result-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.ocr-notice {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fffbe6;
  color: #8a5a00;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 保存区域 */
.save-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-item input,
.picker-value {
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #999;
  font-size: 20rpx;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.save-btn {
  flex: 1;
  margin: 0;
  padding: 24rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  color: #333;
  border-radius: 8rpx;
}

.save-btn.primary {
  background: #1890FF;
  color: #fff;
}

/* 识别中 */
.recognizing-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.recognizing-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 80rpx;
  text-align: center;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top-color: #1890FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.recognizing-text {
  font-size: 30rpx;
  color: #333;
}

/* 提示区域 */
.tips-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.tips-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
}
