.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 180rpx;
}

.form {
  background: #fff;
  padding: 20rpx 30rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}

.title-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: bold;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.content-item {
  margin-top: 20rpx;
}

.content-input {
  width: 100%;
  min-height: 400rpx;
  font-size: 30rpx;
  line-height: 1.8;
  padding: 20rpx 0;
}

.word-count {
  display: flex;
  justify-content: flex-end;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.saving {
  color: #1890ff;
  margin-left: 20rpx;
}

.saved {
  color: #52c41a;
  margin-left: 20rpx;
}

.toolbar {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid #eee;
  border-bottom: 1rpx solid #eee;
}

.tool-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

.tool-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.tool-text {
  font-size: 26rpx;
  color: #666;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-save {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.btn-save::after {
  border: none;
}
