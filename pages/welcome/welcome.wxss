.welcome-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1aad19 0%, #0e8a0d 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  gap: 16rpx;
  margin-top: 80rpx;
  margin-bottom: 100rpx;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s;
}

.step-dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: #fff;
}

/* 内容区域 */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.icon-wrapper {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.step-icon {
  font-size: 100rpx;
}

.step-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.step-desc {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  padding: 0 40rpx;
}

/* 按钮区域 */
.button-area {
  width: 100%;
  padding: 40rpx 0;
}

.btn-primary {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #fff;
  color: #1aad19;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.btn-text {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
}

.btn-text::after {
  border: none;
}

/* 版本信息 */
.version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 40rpx;
}
