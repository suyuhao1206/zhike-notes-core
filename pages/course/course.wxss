/* pages/course/course.wxss */

.course-header {
  padding: 32rpx;
}

.course-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.course-info {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.info-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.section {
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-action {
  font-size: 26rpx;
  color: #1890FF;
}

.section-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.note-item {
  padding: 24rpx;
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.note-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.note-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-left: 16rpx;
}

.note-summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.note-footer {
  display: flex;
  gap: 12rpx;
}

.note-tag {
  font-size: 22rpx;
  color: var(--primary-color);
  background-color: rgba(24, 144, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-placeholder);
}
