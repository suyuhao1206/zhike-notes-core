<view class="container">
  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 笔记详情 -->
  <view class="note-detail" wx:else>
    <!-- 头部信息 -->
    <view class="note-header card">
      <view class="header-top">
        <text class="course-name">{{note.courseName || '未分类'}}</text>
        <text class="create-time">{{note.createTimeFormatted || '刚刚'}}</text>
      </view>
      <text class="note-title">{{note.title || '无标题笔记'}}</text>
      <view class="note-meta" wx:if="{{note.duration || note.qaCount}}">
        <text class="meta-item" wx:if="{{note.duration}}">时长: {{note.duration}}</text>
        <text class="meta-item" wx:if="{{note.qaCount}}">答疑: {{note.qaCount}}次</text>
      </view>
      <view class="tag-list" wx:if="{{note.tags && note.tags.length > 0}}">
        <text class="tag" wx:for="{{note.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="action-item" bindtap="goToEdit">
        <text class="action-icon">✏️</text>
        <text class="action-text">编辑</text>
      </view>
      <view class="action-item" bindtap="viewMindMap">
        <text class="action-icon">🧠</text>
        <text class="action-text">思维导图</text>
      </view>
      <view class="action-item" bindtap="goToQA">
        <text class="action-icon">💬</text>
        <text class="action-text">AI答疑</text>
      </view>
      <view class="action-item" bindtap="generateReview">
        <text class="action-icon">📝</text>
        <text class="action-text">生成试卷</text>
      </view>
    </view>

    <view class="action-bar second-bar">
      <view class="action-item" bindtap="generateFlashcard">
        <text class="action-icon">📚</text>
        <text class="action-text">背诵卡片</text>
      </view>
      <view class="action-item" bindtap="shareNote">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </view>
      <view class="action-item" bindtap="deleteNote">
        <text class="action-icon">🗑️</text>
        <text class="action-text">删除</text>
      </view>
    </view>

    <!-- 笔记内容 -->
    <view class="note-content card">
      <view class="content-header">
        <text class="content-title">笔记内容</text>
        <text class="edit-btn" bindtap="startEdit" wx:if="{{!isEditing}}">编辑</text>
      </view>

      <!-- 编辑模式 -->
      <view class="edit-container" wx:if="{{isEditing}}">
        <textarea 
          class="edit-input" 
          value="{{editContent}}" 
          bindinput="onInput"
          placeholder="请输入笔记内容"
          maxlength="-1"
        />
        <view class="edit-actions">
          <button class="btn-cancel" bindtap="cancelEdit">取消</button>
          <button class="btn-save" bindtap="saveEdit">保存</button>
        </view>
      </view>

      <!-- 阅读模式 -->
      <view class="content-body" wx:else>
        <rich-text nodes="{{note.content}}"></rich-text>
      </view>
    </view>

    <!-- 思维导图预览 -->
    <view class="mindmap-preview card" wx:if="{{mindMap}}">
      <view class="preview-header">
        <text class="preview-title">📚 知识点结构</text>
        <text class="preview-more" bindtap="viewMindMap">{{showFullMindMap ? '收起' : '展开查看'}}</text>
      </view>
      
      <!-- 折叠状态：只显示前3个 -->
      <view class="mindmap-container" wx:if="{{!showFullMindMap && mindMap.children}}">
        <view class="mindmap-title">{{mindMap.title}}</view>
        <view class="mindmap-sections">
          <view class="mindmap-section" wx:for="{{mindMapPreviewSections}}" wx:key="name" wx:for-item="section">
            <view class="section-header">
              <text class="section-icon">📌</text>
              <text class="section-name">{{section.name}}</text>
            </view>
            <view class="section-items" wx:if="{{section.children && section.children.length > 0}}">
              <view class="item-row" wx:for="{{section.children}}" wx:key="name" wx:for-item="item">
                <text class="item-bullet">•</text>
                <text class="item-text">{{item.name}}</text>
              </view>
              <view class="item-more" wx:if="{{section.moreCount > 0}}">
                <text class="more-text">还有 {{section.moreCount}} 项...</text>
              </view>
            </view>
          </view>
          <view class="sections-more" wx:if="{{mindMap.children.length > 3}}">
            <text class="more-text">还有 {{mindMap.children.length - 3}} 个知识点...</text>
          </view>
        </view>
      </view>
      
      <!-- 展开状态：显示全部 -->
      <view class="mindmap-container mindmap-full" wx:if="{{showFullMindMap && mindMap.children}}">
        <view class="mindmap-title">{{mindMap.title}}</view>
        <view class="mindmap-graph">
          <view class="graph-root">{{mindMap.title}}</view>
          <view class="graph-branches">
            <view class="graph-branch" wx:for="{{mindMapSections}}" wx:key="name" wx:for-item="section">
              <view class="graph-line"></view>
              <view class="graph-node">{{section.name}}</view>
            </view>
          </view>
        </view>
        <view class="mindmap-sections">
          <view class="mindmap-section" wx:for="{{mindMapSections}}" wx:key="name" wx:for-item="section">
            <view class="section-header">
              <text class="section-icon">📌</text>
              <text class="section-name">{{section.name}}</text>
            </view>
            <view class="section-items" wx:if="{{section.children && section.children.length > 0}}">
              <view class="item-row" wx:for="{{section.children}}" wx:key="name" wx:for-item="item">
                <text class="item-bullet">•</text>
                <view class="item-content">
                  <text class="item-text">{{item.name}}</text>
                  <view class="sub-items" wx:if="{{item.children && item.children.length > 0}}">
                    <view class="sub-item" wx:for="{{item.children}}" wx:key="name" wx:for-item="subItem">
                      <text class="sub-bullet">◦</text>
                      <text class="sub-text">{{subItem.name}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 无思维导图提示 -->
    <view class="mindmap-empty card" wx:if="{{!mindMap || !mindMap.children || mindMap.children.length === 0}}">
      <view class="empty-header">
        <text class="empty-icon">🧠</text>
        <text class="empty-title">知识点结构</text>
      </view>
      <view class="empty-content">
        <text class="empty-hint">点击下方"思维导图"按钮生成</text>
        <button class="generate-btn" bindtap="viewMindMap" loading="{{isGeneratingMindMap}}">
          {{isGeneratingMindMap ? '生成中...' : '生成思维导图'}}
        </button>
      </view>
    </view>
  </view>
</view>
