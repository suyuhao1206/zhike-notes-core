<view class="container">
  <view class="card" wx:if="{{pageError}}">
    <view class="section-title">录音功能初始化失败</view>
    <view style="margin-top: 16rpx; color: #ff4d4f; font-size: 26rpx;">{{pageError}}</view>
    <button style="margin-top: 20rpx;" bindtap="retryInit">重试</button>
  </view>

  <!-- 录音控制区域 -->
  <view class="record-control card" wx:if="{{!pageError}}">
    <view class="record-status">
      <text class="status-icon {{isRecording ? 'recording' : ''}}">
        {{isRecording ? '🔴' : '⚪'}}
      </text>
      <text class="status-text">
        {{isRecording ? '录音中...' : '点击开始录音'}}
      </text>
    </view>
    
    <view class="record-time" wx:if="{{isRecording}}">
      <text class="time-text">{{recordingTimeText}}</text>
    </view>
    
    <view class="record-btn-wrapper">
      <view class="record-btn {{isRecording ? 'recording' : ''}}" bindtap="toggleRecord">
        <text class="btn-icon">{{isRecording ? '⏹️' : '🎤'}}</text>
        <text class="btn-text">{{isRecording ? '结束录音' : '开始录音'}}</text>
      </view>
    </view>
  </view>

  <!-- 课程选择 -->
  <view class="course-select card" wx:if="{{!isRecording && !pageError}}">
    <view class="section-title">选择课程</view>
    <picker mode="selector" range="{{courseList}}" range-key="name" value="{{courseIndex}}" bindchange="onCourseChange">
      <view class="picker">
        <text>{{selectedCourseName}}</text>
        <text class="picker-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 录音记录列表 -->
  <view class="section" wx:if="{{!pageError}}">
    <view class="section-title">录音记录</view>
    
    <view class="record-list">
      <view class="record-item card" wx:for="{{recordList}}" wx:key="id" bindtap="viewRecord" data-id="{{item.id}}">
        <view class="record-item-header">
          <text class="record-course">{{item.courseName}}</text>
          <text class="record-item-time">{{item.createTime}}</text>
        </view>
        <view class="record-item-info">
          <text class="record-duration">⏱️ {{item.durationText}}</text>
          <text class="record-status {{item.status}}">
            {{item.statusText}}
          </text>
        </view>
      </view>
      
      <view class="empty-state" wx:if="{{recordList.length === 0}}">
        <text class="empty-text">还没有录音记录</text>
      </view>
    </view>
  </view>
</view>
