.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.status-card {
  background: linear-gradient(135deg, #1890FF 0%, #36CFC9 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
}

.status-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.status-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon .icon {
  font-size: 40rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.online {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.status-badge.offline {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890FF;
}

.storage-bar {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
}

.bar-hint {
  font-size: 22rpx;
  color: #999;
}

.sync-section, .manage-section, .history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.sync-card, .manage-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.sync-card:last-child, .manage-item:last-child {
  margin-bottom: 0;
}

.sync-icon, .manage-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.sync-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sync-title, .manage-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.sync-desc {
  font-size: 24rpx;
  color: #999;
}

.sync-arrow, .manage-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.history-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.history-title {
  font-size: 26rpx;
  color: #333;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-status {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.history-status.success {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.history-status.failed {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}
