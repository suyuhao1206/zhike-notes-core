<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <view class="search-input-placeholder">
      <text class="search-icon">🔍</text>
      <text class="search-text">搜索笔记、课程内容...</text>
    </view>
  </view>

  <!-- 欢迎区域 -->
  <view class="welcome-card card">
    <view class="welcome-text">
      <text class="welcome-title">欢迎使用智课笔记</text>
      <text class="welcome-subtitle">让每一堂课都自动生成高质量笔记</text>
    </view>
    <view class="quick-actions">
      <view class="action-btn" bindtap="startOCR">
        <text class="action-icon">📷</text>
        <text class="action-text">拍图识别</text>
      </view>
      <view class="action-btn" bindtap="askQuestion">
        <text class="action-icon">💬</text>
        <text class="action-text">AI 答疑</text>
      </view>
      <view class="action-btn" bindtap="goToReview">
        <text class="action-icon">📝</text>
        <text class="action-text">复习训练</text>
      </view>
    </view>
  </view>

  <!-- 课程列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">我的课程</text>
      <text class="section-more" bindtap="viewAllCourses">查看全部 ></text>
    </view>
    
    <view class="course-list">
      <view class="course-item card" wx:for="{{courseList}}" wx:key="id" bindtap="goToCourse" data-id="{{item._id || item.id}}">
        <view class="course-info">
          <text class="course-name">{{item.name}}</text>
          <text class="course-note-count">{{item.noteCount}}条笔记</text>
        </view>
        <view class="course-time">{{item.updateTime}}</view>
      </view>
      
      <view class="empty-state" wx:if="{{courseList.length === 0}}">
        <text class="empty-icon">📚</text>
        <text class="empty-text">还没有课程</text>
        <text class="empty-hint">点击右下角"+"创建第一个课程</text>
      </view>
    </view>
  </view>

  <!-- 最近笔记 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">最近笔记</text>
      <text class="section-more" bindtap="viewAllNotes">查看全部 ></text>
    </view>
    
    <view class="note-list">
      <view class="note-item card" wx:for="{{recentNotes}}" wx:key="id" bindtap="goToNote" data-id="{{item._id || item.id}}">
        <view class="note-header">
          <text class="note-course">{{item.courseName}}</text>
          <text class="note-time">{{item.createTime}}</text>
        </view>
        <text class="note-title">{{item.title}}</text>
        <text class="note-summary">{{item.summary}}</text>
      </view>
      
      <view class="empty-state" wx:if="{{recentNotes.length === 0}}">
        <text class="empty-icon">📝</text>
        <text class="empty-text">还没有笔记</text>
        <text class="empty-hint">点击课程创建笔记，或使用录音/拍图功能</text>
      </view>
    </view>
  </view>

  <!-- 快速创建按钮 -->
  <view class="quick-create-fab" bindtap="showQuickCreate">
    <text class="fab-icon">+</text>
  </view>

  <!-- 快速创建菜单 -->
  <view class="quick-create-menu" wx:if="{{showQuickMenu}}">
    <view class="menu-mask" bindtap="hideQuickCreate"></view>
    <view class="menu-content">
      <view class="menu-item" bindtap="createCourse">
        <text class="menu-icon">📚</text>
        <text class="menu-text">创建课程</text>
      </view>
      <view class="menu-item" bindtap="createNote">
        <text class="menu-icon">📝</text>
        <text class="menu-text">新建笔记</text>
      </view>
      <view class="menu-item" bindtap="startRecord">
        <text class="menu-icon">🎤</text>
        <text class="menu-text">录音转写</text>
      </view>
      <view class="menu-item" bindtap="startOCR">
        <text class="menu-icon">📷</text>
        <text class="menu-text">拍图识别</text>
      </view>
    </view>
  </view>
</view>
