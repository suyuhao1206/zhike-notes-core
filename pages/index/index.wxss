/* pages/index/index.wxss */

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input-placeholder {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-text {
  font-size: 28rpx;
  color: #999;
}

.welcome-card {
  background: linear-gradient(135deg, #1890FF 0%, #36CFC9 100%);
  color: #FFFFFF;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.quick-actions {
  display: flex;
  margin-top: 32rpx;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 24rpx;
}

.section {
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.course-item,
.note-item {
  padding: 24rpx;
}

.course-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.course-note-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.course-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.note-course {
  font-size: 24rpx;
  color: var(--primary-color);
  background-color: rgba(24, 144, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.note-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.note-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.note-summary {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 24rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-placeholder);
}
