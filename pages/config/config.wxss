.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 信息卡片 */
.info-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.info-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 15rpx;
}

.help-link {
  font-size: 26rpx;
  text-decoration: underline;
  opacity: 0.9;
}

/* 配置卡片 */
.config-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 输入组 */
.input-group {
  margin-bottom: 25rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 按钮组 */
.button-group {
  margin-top: 30rpx;
}

.btn-test {
  background-color: #52c41a;
  color: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.btn-save {
  background-color: #1890ff;
  color: #fff;
  border-radius: 8rpx;
}

/* 提示 */
.tips {
  margin-top: 30rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
}
