<view class="container">
  <!-- 课程列表 -->
  <view class="course-list">
    <view
      class="course-card"
      wx:for="{{courses}}"
      wx:key="id"
    >
      <view class="course-info" bindtap="viewCourseNotes" data-id="{{item._id || item.id}}">
        <view class="course-icon">📚</view>
        <view class="course-detail">
          <text class="course-name">{{item.name}}</text>
          <text class="course-meta">{{item.noteCount}} 篇笔记</text>
        </view>
      </view>
      <view class="course-actions">
        <text class="action-btn" bindtap="showEditModal" data-course="{{item}}">编辑</text>
        <text class="action-btn delete" bindtap="deleteCourse" data-id="{{item._id || item.id}}">删除</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{courses.length === 0 && !loading}}">
      <text class="empty-icon">📚</text>
      <text class="empty-text">暂无课程</text>
      <text class="empty-hint">点击右下角按钮添加课程</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab" bindtap="showAddModal">
    <text class="fab-icon">+</text>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal" wx:if="{{isEditing}}">
    <view class="modal-mask" bindtap="hideModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">{{editingCourse ? '编辑课程' : '添加课程'}}</text>
      </view>
      <view class="modal-body">
        <input
          class="modal-input"
          type="text"
          placeholder="请输入课程名称"
          value="{{newCourseName}}"
          bindinput="onNameInput"
          focus
        />
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-confirm" bindtap="saveCourse">确定</button>
      </view>
    </view>
  </view>
</view>
