/* pages/qa/qa.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 200rpx;
}

.message-item {
  margin-bottom: 20rpx;
  max-width: 85%;
}

.message-item.user {
  margin-left: auto;
}

.message-item.ai {
  margin-right: auto;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.sender-name {
  font-size: 24rpx;
  font-weight: bold;
}

.message-item.user .sender-name {
  color: #1890FF;
}

.message-item.ai .sender-name {
  color: #52C41A;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.message-content {
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-item.user .message-content {
  background: #1890FF;
  color: #fff;
}

.message-item.ai .message-content {
  background: #fff;
  color: #333;
}

.message-actions {
  margin-top: 8rpx;
}

.action-btn {
  font-size: 22rpx;
  color: #1890FF;
}

/* 发送中状态 */
.message-item.sending {
  opacity: 0.8;
}

.typing-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.typing-indicator {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: #1890FF;
  border-radius: 50%;
  animation: typing 1s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 100% {
    opacity: 0.3;
  }
  50% {
    opacity: 1;
  }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

/* 快捷问题 */
.quick-questions {
  position: fixed;
  bottom: 200rpx;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
}

.quick-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.quick-item {
  padding: 10rpx 16rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 8rpx;
  border: 1rpx solid #1890FF;
}

.quick-text {
  font-size: 24rpx;
  color: #1890FF;
}

/* 输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-container {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 12rpx;
}

.input-box {
  flex: 1;
  min-height: 40rpx;
  max-height: 120rpx;
  font-size: 28rpx;
  line-height: 1.4;
}

.send-btn {
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #E8E8E8;
  color: #999;
}

.send-btn.active {
  background: #1890FF;
  color: #fff;
}

.send-btn[disabled] {
  opacity: 0.6;
}

.input-actions {
  margin-top: 12rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #999;
}