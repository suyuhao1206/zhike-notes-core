<view class="backup-container">
  <!-- 备份信息 -->
  <view class="info-card card">
    <view class="info-title">备份信息</view>
    <view class="info-item">
      <text class="info-label">上次备份</text>
      <text class="info-value">{{lastBackupTime || '未备份'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">备份大小</text>
      <text class="info-value">{{backupSizeText}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-card card">
    <view class="action-title">数据管理</view>

    <view class="action-item" bindtap="exportData">
      <view class="action-left">
        <text class="action-icon">📤</text>
        <view class="action-info">
          <text class="action-name">导出数据</text>
          <text class="action-desc">将所有数据导出为JSON文件</text>
        </view>
      </view>
      <text class="action-arrow">></text>
    </view>

    <view class="action-item" bindtap="importData">
      <view class="action-left">
        <text class="action-icon">📥</text>
        <view class="action-info">
          <text class="action-name">导入数据</text>
          <text class="action-desc">从JSON文件恢复数据</text>
        </view>
      </view>
      <text class="action-arrow">></text>
    </view>

    <view class="action-item danger" bindtap="clearAllData">
      <view class="action-left">
        <text class="action-icon">🗑️</text>
        <view class="action-info">
          <text class="action-name">清除所有数据</text>
          <text class="action-desc">删除所有本地数据（不可恢复）</text>
        </view>
      </view>
      <text class="action-arrow">></text>
    </view>
  </view>

  <!-- 使用说明 -->
  <view class="tips-card card">
    <view class="tips-title">使用说明</view>
    <view class="tips-content">
      <text class="tip-item">1. 导出数据会将所有课程、笔记、错题等数据导出为JSON格式</text>
      <text class="tip-item">2. 导出的数据会复制到剪贴板，建议粘贴保存到备忘录或文件</text>
      <text class="tip-item">3. 导入数据时，请将JSON数据复制到剪贴板后点击导入</text>
      <text class="tip-item">4. 导入数据会覆盖现有数据，请谨慎操作</text>
    </view>
  </view>
</view>
