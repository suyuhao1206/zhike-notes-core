.record-control {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.record-status {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.status-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.record-time {
  text-align: center;
  margin-bottom: 24rpx;
}

.time-text {
  font-size: 50rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.record-btn-wrapper {
  display: flex;
  justify-content: center;
}

.record-btn {
  width: 360rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-btn.recording {
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7a45 100%);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
}

.course-select {
  margin-bottom: 24rpx;
  padding: 24rpx;
}

.picker {
  margin-top: 16rpx;
  background: #f7f9fc;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.picker-arrow {
  color: var(--text-secondary);
}

.section {
  margin-top: 8rpx;
}

.record-list {
  margin-top: 14rpx;
}

.record-item {
  padding: 22rpx;
  margin-bottom: 16rpx;
}

.record-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-course {
  font-size: 30rpx;
  font-weight: 600;
}

.record-item-time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.record-item-info {
  margin-top: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-duration {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.record-status {
  font-size: 24rpx;
}

.record-status.processing {
  color: #fa8c16;
}

.record-status.completed {
  color: #52c41a;
}

.record-status.failed {
  color: #ff4d4f;
}

.empty-state {
  text-align: center;
  padding: 64rpx 0;
}

.empty-text {
  color: var(--text-placeholder);
}
