/* pages/review/review.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 复习模式选择 */
.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.mode-icon {
  font-size: 48rpx;
}

.mode-info {
  flex: 1;
}

.mode-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.mode-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.mistakes-stats {
  margin-top: 24rpx;
  padding: 16rpx;
  background: rgba(255, 77, 79, 0.1);
  border-radius: 8rpx;
}

.stats-title {
  font-size: 24rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.stats-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.stats-count {
  font-size: 26rpx;
  color: #333;
}

.stats-btn {
  font-size: 24rpx;
  color: #FF4D4F;
}

/* 配置面板 */
.config-panel {
  padding-top: 20rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #1890FF;
}

.config-section {
  margin-top: 24rpx;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.type-list, .count-list, .difficulty-list {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.type-item, .count-item, .difficulty-item {
  padding: 10rpx 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.type-item.selected, .count-item.selected, .difficulty-item.selected {
  background: rgba(24, 144, 255, 0.2);
  color: #1890FF;
}

.type-check {
  margin-right: 8rpx;
}

.generate-btn {
  margin-top: 32rpx;
  background: #1890FF;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

/* 答题页面 */
.exam-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress {
  font-size: 28rpx;
  color: #1890FF;
  background: rgba(24, 144, 255, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.question-card {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
}

.question-type {
  font-size: 24rpx;
  color: #1890FF;
  background: rgba(24, 144, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-bottom: 16rpx;
}

.question-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.option.selected {
  background: rgba(24, 144, 255, 0.2);
  border: 1rpx solid #1890FF;
}

.option-label {
  font-size: 28rpx;
  color: #1890FF;
  font-weight: bold;
}

.option-text {
  font-size: 28rpx;
  color: #333;
}

.fill-input, .short-input {
  margin-top: 16rpx;
}

.input-box {
  width: 100%;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.short-input .input-box {
  min-height: 150rpx;
}

.action-btns {
  margin-top: 32rpx;
}

.next-btn {
  background: #1890FF;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

/* 答题结果 */
.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
}

.score-title {
  font-size: 32rpx;
  color: #333;
}

.score-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #1890FF;
  margin-top: 24rpx;
}

.score-total {
  font-size: 28rpx;
  color: #666;
  margin-top: 8rpx;
}

.score-analysis {
  margin-top: 24rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: #666;
}

.review-btn {
  margin-top: 32rpx;
  background: #1890FF;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 48rpx;
  border-radius: 12rpx;
}

/* 错题本 */
.mistake-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mistake-card {
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
}

.mistake-course {
  font-size: 24rpx;
  color: #1890FF;
  background: rgba(24, 144, 255, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.mistake-question {
  font-size: 28rpx;
  color: #333;
  margin-top: 12rpx;
}

.mistake-answers {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.wrong-answer {
  font-size: 24rpx;
  color: #FF4D4F;
}

.correct-answer {
  font-size: 24rpx;
  color: #52C41A;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
}

.empty-icon {
  font-size: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 12rpx;
}