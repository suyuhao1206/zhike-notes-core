<view class="container">
  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{isLoading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 笔记详情 -->
  <view class="note-detail" wx:else>
    <!-- 头部信息 -->
    <view class="note-header card">
      <view class="header-top">
        <text class="course-name">{{note.courseName}}</text>
        <text class="create-time">{{note.createTime}}</text>
      </view>
      <text class="note-title">{{note.title}}</text>
      <view class="note-meta">
        <text class="meta-item">时长: {{note.duration}}</text>
        <text class="meta-item">答疑: {{note.qaCount}}次</text>
      </view>
      <view class="tag-list">
        <text class="tag" wx:for="{{note.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="action-item" bindtap="viewMindMap">
        <text class="action-icon">🧠</text>
        <text class="action-text">思维导图</text>
      </view>
      <view class="action-item" bindtap="goToQA">
        <text class="action-icon">💬</text>
        <text class="action-text">AI答疑</text>
      </view>
      <view class="action-item" bindtap="generateReview">
        <text class="action-icon">📝</text>
        <text class="action-text">生成试卷</text>
      </view>
      <view class="action-item" bindtap="shareNote">
        <text class="action-icon">📤</text>
        <text class="action-text">分享</text>
      </view>
    </view>

    <!-- 笔记内容 -->
    <view class="note-content card">
      <view class="content-header">
        <text class="content-title">笔记内容</text>
        <text class="edit-btn" bindtap="startEdit" wx:if="{{!isEditing}}">编辑</text>
      </view>

      <!-- 编辑模式 -->
      <view class="edit-container" wx:if="{{isEditing}}">
        <textarea 
          class="edit-input" 
          value="{{editContent}}" 
          bindinput="onInput"
          placeholder="请输入笔记内容"
          maxlength="-1"
        />
        <view class="edit-actions">
          <button class="btn-cancel" bindtap="cancelEdit">取消</button>
          <button class="btn-save" bindtap="saveEdit">保存</button>
        </view>
      </view>

      <!-- 阅读模式 -->
      <view class="content-body" wx:else>
        <rich-text nodes="{{note.content}}"></rich-text>
      </view>
    </view>

    <!-- 思维导图预览 -->
    <view class="mindmap-preview card" wx:if="{{mindMap}}">
      <view class="preview-header">
        <text class="preview-title">知识点结构</text>
        <text class="preview-more" bindtap="viewMindMap">查看详情 ></text>
      </view>
      <view class="mindmap-tree">
        <view class="tree-node root">
          <text class="node-title">{{mindMap.title}}</text>
          <view class="node-children">
            <view class="tree-node child" wx:for="{{mindMap.children}}" wx:key="title">
              <text class="node-title">{{item.title}}</text>
              <view class="node-leafs">
                <text class="leaf" wx:for="{{item.children}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 更多操作 -->
    <view class="more-actions card">
      <text class="more-title">更多功能</text>
      <view class="more-list">
        <view class="more-item" bindtap="generateFlashcard">
          <text class="more-icon">📚</text>
          <text class="more-text">生成背诵卡片</text>
        </view>
      </view>
    </view>
  </view>
</view>