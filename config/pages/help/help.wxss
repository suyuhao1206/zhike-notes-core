.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.header {
  text-align: center;
  padding: 40rpx 20rpx;
  margin-bottom: 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

/* 分区 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 帮助列表 */
.help-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

.help-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  cursor: pointer;
}

.help-q {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.help-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.help-arrow.expanded {
  transform: rotate(180deg);
}

.help-content {
  padding: 0 24rpx 24rpx;
  background: #fff;
}

.help-a {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-line;
}

/* 功能网格 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.feature-item {
  text-align: center;
  padding: 24rpx 16rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.feature-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
}

/* 联系卡片 */
.contact-card {
  text-align: center;
  padding: 40rpx;
  background: linear-gradient(135deg, #1890FF 0%, #36a3ff 100%);
  border-radius: 16rpx;
}

.contact-text {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 16rpx;
}

.contact-email {
  display: block;
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.feedback-btn {
  margin: 0;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  background: #fff;
  color: #1890FF;
  border-radius: 8rpx;
  display: inline-block;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 40rpx;
}

.version-info text {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
