<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索笔记..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- 课程筛选 -->
  <view class="course-filter">
    <scroll-view class="course-scroll" scroll-x>
      <view
        class="course-tag {{selectedCourse === (item.id === 0 ? null : item.id) ? 'active' : ''}}"
        wx:for="{{courses}}"
        wx:key="id"
        bindtap="selectCourse"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 笔记列表 -->
  <view class="notes-list">
    <view
      class="note-card"
      wx:for="{{filteredNotes}}"
      wx:key="id"
      bindtap="viewNote"
      data-id="{{item.id}}"
    >
      <view class="note-header">
        <text class="note-course">{{item.courseName}}</text>
        <text class="note-time">{{item.createTimeFormatted}}</text>
      </view>
      <view class="note-title">{{item.title}}</view>
      <view class="note-summary">{{item.summaryShort}}</view>
      <view class="note-footer">
        <text class="note-duration" wx:if="{{item.duration}}">⏱️ {{item.duration}}秒</text>
        <view class="note-actions" catchtap="stopPropagation">
          <text class="action-btn delete" catchtap="deleteNote" data-id="{{item.id}}">删除</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredNotes.length === 0 && !loading}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无笔记</text>
      <text class="empty-hint">点击右下角按钮开始录音</text>
    </view>
  </view>

  <!-- 新建按钮 -->
  <view class="fab" bindtap="createNote">
    <text class="fab-icon">+</text>
  </view>
</view>
