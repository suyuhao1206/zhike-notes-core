.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #1890FF 0%, #36a3ff 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  color: #fff;
}

.stat-item:not(:last-child) {
  border-right: 1rpx solid rgba(255,255,255,0.3);
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-pending {
  color: #ffeb3b;
}

.stat-fixed {
  color: #90ee90;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.filter-label {
  color: #666;
}

.filter-value {
  color: #333;
  margin: 0 10rpx;
}

.filter-arrow {
  color: #999;
  font-size: 20rpx;
}

.review-btn {
  margin: 0;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  background: #1890FF;
  color: #fff;
  border-radius: 8rpx;
  line-height: 1.4;
}

.review-btn[disabled] {
  background: #ccc;
}

/* 错题列表 */
.mistake-list {
  margin-bottom: 40rpx;
}

.mistake-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.mistake-card.fixed {
  opacity: 0.7;
}

.mistake-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-tag {
  font-size: 24rpx;
  color: #1890FF;
  background: rgba(24,144,255,0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-pending {
  color: #ff9800;
  background: rgba(255,152,0,0.1);
}

.status-fixed {
  color: #52c41a;
  background: rgba(82,196,26,0.1);
}

.mistake-content {
  margin-bottom: 16rpx;
}

.mistake-content .label {
  color: #666;
  font-size: 26rpx;
}

.mistake-content .text {
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

.question {
  margin-bottom: 12rpx;
}

.wrong-answer {
  margin-bottom: 12rpx;
}

.wrong-answer .text {
  color: #ff4d4f;
}

.correct-answer .text {
  color: #52c41a;
}

.mistake-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  margin: 0;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

.fix-btn {
  background: #52c41a;
  color: #fff;
}

.retry-btn {
  background: #1890FF;
  color: #fff;
}

.delete-btn {
  background: #ff4d4f;
  color: #fff;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  display: block;
  font-size: 26rpx;
  color: #bbb;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top-color: #1890FF;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
