.container {
  padding: 20px;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.title {
  font-size: 24px;
  font-weight: bold;
}

.retry-btn {
  font-size: 14px;
  padding: 8px 16px;
}

.test-list {
  margin-bottom: 20px;
}

.test-item {
  padding: 15px;
  margin-bottom: 10px;
  border-radius: 8px;
  border-left: 4px solid #ccc;
}

.test-item.success {
  background-color: #f0f9eb;
  border-left-color: #67c23a;
}

.test-item.warning {
  background-color: #fdf6ec;
  border-left-color: #e6a23c;
}

.test-item.error {
  background-color: #fef0f0;
  border-left-color: #f56c6c;
}

.test-name {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 8px;
}

.test-status {
  font-size: 20px;
  margin-bottom: 8px;
}

.test-item.success .test-status {
  color: #67c23a;
}

.test-item.warning .test-status {
  color: #e6a23c;
}

.test-item.error .test-status {
  color: #f56c6c;
}

.test-message {
  font-size: 14px;
  color: #666;
}

.tips {
  padding: 15px;
  background-color: #f4f4f5;
  border-radius: 8px;
}

.tips-title {
  font-weight: bold;
  display: block;
  margin-bottom: 8px;
}

.tips-content {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}
