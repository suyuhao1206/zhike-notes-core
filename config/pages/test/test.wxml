<view class="container">
  <view class="header">
    <text class="title">系统诊断</text>
    <text class="subtitle">全面检查云开发和 AI 功能</text>
  </view>

  <view class="test-list">
    <view 
      wx:for="{{testResults}}" 
      wx:key="name" 
      class="test-item {{item.status}}"
      bindtap="showDetail"
      data-index="{{index}}"
    >
      <view class="test-header">
        <text class="test-name">{{item.name}}</text>
        <text class="test-icon">
          <text wx:if="{{item.status === 'success'}}">✓</text>
          <text wx:elif="{{item.status === 'error'}}">✗</text>
          <text wx:else>○</text>
        </text>
      </view>
      <text class="test-message">{{item.message}}</text>
    </view>
  </view>

  <view class="button-area">
    <button 
      class="retry-btn" 
      bindtap="retry"
      disabled="{{testing}}"
    >
      {{testing ? '测试中...' : '重新测试'}}
    </button>
  </view>

  <view class="tips" wx:if="{{testResults.length > 0}}">
    <text class="tips-title">💡 提示</text>
    <text class="tips-text">• 点击测试项查看详细信息</text>
    <text class="tips-text">• 如果 AI 测试失败，请检查云开发控制台的 AI 能力是否开通</text>
    <text class="tips-text">• 如果云函数失败，请右键重新上传部署云函数</text>
  </view>
</view>
